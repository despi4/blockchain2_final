# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Your MetaMask private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC (from Alchemy/Infura)
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your_key

# Arbiscan API key (for contract verification)
# Get free key at: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_key

# Core protocol addresses on Arbitrum Sepolia
GOV_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
GOLD_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
GAME_ITEMS_ADDRESS=0x0000000000000000000000000000000000000000
AMM_ADDRESS=0x0000000000000000000000000000000000000000
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
LOOT_ADDRESS=0x0000000000000000000000000000000000000000
CRAFTING_ADDRESS=0x0000000000000000000000000000000000000000
RENTAL_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Governance layer addresses
GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000

# Frontend / subgraph
WALLETCONNECT_PROJECT_ID=
SUBGRAPH_URL=
