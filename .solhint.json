{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", "^0.8.24"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "no-empty-blocks": "warn",
    "reason-string": "off",
    "custom-errors": "off",
    "named-parameters-mapping": "off",
    "no-console": "off"
  }
}
